# Copy this file to .env and fill in the values.
# docker compose automatically loads .env from the project directory.
#
#   cp .env.example .env
#
# Never commit .env — it is listed in .gitignore and .dockerignore.

# ── AI Generation ──────────────────────────────────────────────────────────────
# Required. Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Authentication (NextAuth + Google OAuth) ───────────────────────────────────
# Generate a strong secret:  openssl rand -base64 32
NEXTAUTH_SECRET=
# Local dev  : http://localhost:8989
# Production : https://yourdomain.com  (must match the Google OAuth redirect URI)
NEXTAUTH_URL=http://localhost:8989
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── WordPress publishing (optional) ───────────────────────────────────────────
# These are fallback credentials used when none are saved in-app.
# You can also configure them in the Settings UI after signing in.
WORDPRESS_SITE_URL=https://your-site.com
WORDPRESS_USERNAME=your-wordpress-username
# Generate in WordPress → Users → Profile → Application Passwords
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Batch API (optional) ───────────────────────────────────────────────────────
# Enables POST /api/generate/batch.  Leave unset to disable the endpoint.
# Use a long random string in production:  openssl rand -hex 32
BATCH_API_SECRET=

# ── Email notifications (optional) ────────────────────────────────────────────
# Used for new-user signup and admin approval emails.
# Leave all SMTP_* values unset to disable email notifications entirely.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=TechScribe Studio <you@yourdomain.com>
ADMIN_EMAIL=you@yourdomain.com

# ── Production Docker (docker-compose.prod.yml) ────────────────────────────────
# Public-facing domain — must match the Traefik router rule.
DOMAIN=techscribe.example.com
# GitHub Container Registry repo path, e.g.  siddonj/techscribe-studio
GITHUB_REPOSITORY=siddonj/techscribe-studio
# Image tag to deploy.  Defaults to "latest" if unset.
IMAGE_TAG=latest
