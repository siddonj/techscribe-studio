# ── AI Generation ─────────────────────────────────────────────────────────────
# Required. Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Authentication (NextAuth + Google OAuth) ───────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Development: http://localhost:3000
# Production:  https://yourdomain.com  (must match Google OAuth redirect URI)
NEXTAUTH_URL=http://localhost:3000
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── WordPress (optional) ───────────────────────────────────────────────────────
# Fallback credentials used when no credentials are saved in-app.
# These are optional — you can configure WordPress in the Settings UI instead.
WORDPRESS_SITE_URL=https://your-site.com
WORDPRESS_USERNAME=your-wordpress-username
# Generate an application password in WordPress → Users → Profile → Application Passwords
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Batch API (optional) ───────────────────────────────────────────────────────
# Required to enable POST /api/generate/batch. Leave unset to disable.
# Use a long random string in production: openssl rand -hex 32
BATCH_API_SECRET=

# ── Email notifications (optional) ────────────────────────────────────────────
# Used for new user signup and approval notification emails.
# Leave all unset to disable email notifications.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=TechScribe Studio <you@yourdomain.com>
ADMIN_EMAIL=you@yourdomain.com

# ── Production Docker (docker-compose.prod.yml) ───────────────────────────────
# Your public domain — must match the Traefik router rule
DOMAIN=techscribe.example.com
